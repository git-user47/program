#include <stdio.h>
#include <stdlib.h>

int main() {
    int n, i, j, pos, seek = 0;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    int req[n], visited[n];

    printf("Enter request queue: ");
    for(i = 0; i < n; i++) {
        scanf("%d", &req[i]);
        visited[i] = 0;
    }

    printf("Enter initial head position: ");
    scanf("%d", &pos);

    // SSTF Scheduling
    for(i = 0; i < n; i++) {
        int min = 10000, index = -1;

        for(j = 0; j < n; j++) {
            if(!visited[j]) {
                int dist = abs(pos - req[j]);
                if(dist < min) {
                    min = dist;
                    index = j;
                }
            }
        }

        seek += min;
        pos = req[index];
        visited[index] = 1;
    }

    printf("Total Seek Time = %d\n", seek);

    return 0;
}
