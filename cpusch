#include <stdio.h>

int main() {
    int n, i, j, t, min, idx;
    int at[10], bt[10], pr[10];
    
    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("Process %d Arrival Time: ", i+1);
        scanf("%d", &at[i]);
        printf("Process %d Burst Time: ", i+1);
        scanf("%d", &bt[i]);
        printf("Process %d Priority: ", i+1);
        scanf("%d", &pr[i]);
    }

    // FCFS
    int wt_fcfs[10], time = 0;
    float avg_fcfs = 0;

    for(i = 0; i < n; i++) {
        if(time < at[i])
            time = at[i];
        wt_fcfs[i] = time - at[i];
        time += bt[i];
        avg_fcfs += wt_fcfs[i];
    }
    avg_fcfs /= n;

    // SRTF
    int rt[10], wt_srtf[10], complete = 0;
    int min_bt, shortest = 0;
    int finish_time, check = 0;
    float avg_srtf = 0;

    for(i = 0; i < n; i++)
        rt[i] = bt[i];

    t = 0;
    while(complete != n) {
        min_bt = 9999;
        check = 0;

        for(i = 0; i < n; i++) {
            if(at[i] <= t && rt[i] > 0 && rt[i] < min_bt) {
                min_bt = rt[i];
                shortest = i;
                check = 1;
            }
        }

        if(check == 0) {
            t++;
            continue;
        }

        rt[shortest]--;

        if(rt[shortest] == 0) {
            complete++;
            finish_time = t + 1;
            wt_srtf[shortest] = finish_time - bt[shortest] - at[shortest];
            if(wt_srtf[shortest] < 0)
                wt_srtf[shortest] = 0;
        }
        t++;
    }

    for(i = 0; i < n; i++)
        avg_srtf += wt_srtf[i];
    avg_srtf /= n;

    // NP PRI
    int done[10] = {0}, wt_pr[10];
    float avg_pr = 0;
    time = 0;

    for(i = 0; i < n; i++) {
        int max_pr = -1;
        idx = -1;

        for(j = 0; j < n; j++) {
            if(at[j] <= time && done[j] == 0) {
                if(pr[j] > max_pr) {
                    max_pr = pr[j];
                    idx = j;
                }
            }
        }

        if(idx == -1) {
            time++;
            i--;
            continue;
        }

        wt_pr[idx] = time - at[idx];
        time += bt[idx];
        done[idx] = 1;
        avg_pr += wt_pr[idx];
    }
    avg_pr /= n;

    //RR
    int qt = 3;
    int rem_bt[10], wt_rr[10] = {0};
    float avg_rr = 0;

    for(i = 0; i < n; i++)
        rem_bt[i] = bt[i];

    time = 0;
    int flag = 1;

    while(flag) {
        flag = 0;

        for(i = 0; i < n; i++) {
            if(rem_bt[i] > 0) {
                flag = 1;

                if(rem_bt[i] > qt) {
                    time += qt;
                    rem_bt[i] -= qt;
                } else {
                    time += rem_bt[i];
                    wt_rr[i] = time - bt[i] - at[i];
                    rem_bt[i] = 0;
                }
            }
        }
    }

    for(i = 0; i < n; i++)
        avg_rr += wt_rr[i];
    avg_rr /= n;

    //RESULT 
    printf("\nAverage Waiting Time:\n");
    printf("FCFS = %.2f\n", avg_fcfs);
    printf("SRTF = %.2f\n", avg_srtf);
    printf("Priority = %.2f\n", avg_pr);
    printf("RR = %.2f\n", avg_rr);

    float min_avg = avg_fcfs;
    char best[20] = "FCFS";

    if(avg_srtf < min_avg) {
        min_avg = avg_srtf;
        strcpy(best, "SRTF");
    }
    if(avg_pr < min_avg) {
        min_avg = avg_pr;
        strcpy(best, "Priority");
    }
    if(avg_rr < min_avg) {
        min_avg = avg_rr;
        strcpy(best, "RR");
    }

    printf("\nBest Algorithm: %s\n", best);

    return 0;
}
